
{
  "openapi": "3.0.3",
  "info": {
    "title": "API GrowTweeter",
    "description": "Recursos para controle e gerenciamento da API do GrowTweeter",
    "version": "1.0.0"
  },
  "servers": [
    {"url": "http://localhost:3000", "description": "Local"},
    {"url": "https://api-growtweeter-edicodewes3.onrender.com", "description": "Render"}
  ],
  "tags": [
    {"name": "Users", "description": "Funcionalidades para usuários"},
    {"name": "Login", "description": "Autenticação"},
    {"name": "Tweets", "description": "Funcionalidades para tweets"},
    {"name": "Likes", "description": "Curtidas"},
    {"name": "Replies", "description": "Respostas"},
    {"name": "Followers", "description": "Seguidores"},
    {"name": "Feed", "description": "Feed"}
  ],
  "paths": {
    "/user": {
      "get": {
        "tags": ["Users"],
        "summary": "Listar usuários",
        "responses": {
          "200": {"description": "Usuários listados com sucesso"},
          "500": {"description": "Erro inesperado"}
        }
      },
      "post": {
        "tags": ["Users"],
        "summary": "Criar usuário",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CreateUser"}}}
        },
        "responses": {
          "200": {"description": "Usuário criado com sucesso"},
          "201": {"description": "Usuário criado com sucesso"},
          "400": {"description": "Dados inválidos"},
          "409": {"description": "E-mail ou username já cadastrado"},
          "500": {"description": "Erro inesperado"}
        }
      }
    },
    "/user/{id}": {
      "put": {
        "tags": ["Users"],
        "summary": "Atualizar usuário",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/UpdateUser"}}}
        },
        "responses": {
          "200": {"description": "Usuário atualizado com sucesso"},
          "400": {"description": "UUID inválido"},
          "404": {"description": "Usuário não encontrado"},
          "409": {"description": "Username já cadastrado"},
          "500": {"description": "Erro inesperado"}
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Excluir usuário",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "responses": {
          "200": {"description": "Usuário deletado com sucesso"},
          "400": {"description": "UUID inválido"},
          "404": {"description": "Usuário não encontrado"},
          "500": {"description": "Erro inesperado"}
        }
      }
    },
    "/auth/signin": {
      "post": {
        "tags": ["Login"],
        "summary": "Login do usuário",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Login"}}}
        },
        "responses": {
          "200": {"description": "Usuário autenticado"},
          "401": {"description": "Credenciais inválidas"},
          "500": {"description": "Erro inesperado"}
        }
      }
    },
    "/tweet": {
      "get": {
        "tags": ["Tweets"],
        "summary": "Listar tweets",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "limit", "in": "query", "required": false, "schema": {"type": "integer", "example": 10}},
          {"name": "page", "in": "query", "required": false, "schema": {"type": "integer", "example": 1}}
        ],
        "responses": {
          "200": {"description": "Tweets listados com sucesso"},
          "401": {"description": "Token inválido"},
          "500": {"description": "Erro inesperado"}
        }
      },
      "post": {
        "tags": ["Tweets"],
        "summary": "Criar tweet",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CreateTweet"}}}
        },
        "responses": {
          "200": {"description": "Tweet cadastrado com sucesso"},
          "201": {"description": "Tweet cadastrado com sucesso"},
          "400": {"description": "Informe um conteúdo para o Tweet"},
          "401": {"description": "Token inválido"},
          "500": {"description": "Erro inesperado"}
        }
      }
    },
    "/tweet/{id}": {
      "put": {
        "tags": ["Tweets"],
        "summary": "Atualizar tweet",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/UpdateTweet"}}}
        },
        "responses": {
          "200": {"description": "Tweet atualizado com sucesso"},
          "400": {"description": "UUID inválido"},
          "401": {"description": "Token inválido"},
          "404": {"description": "Tweet não encontrado"},
          "500": {"description": "Erro inesperado"}
        }
      },
      "delete": {
        "tags": ["Tweets"],
        "summary": "Apagar tweet",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "responses": {
          "200": {"description": "Tweet deletado com sucesso"},
          "400": {"description": "UUID inválido"},
          "401": {"description": "Token inválido"},
          "404": {"description": "Tweet não encontrado"},
          "500": {"description": "Erro inesperado"}
        }
      }
    },
    "/like/{tweetId}": {
      "post": {
        "tags": ["Likes"],
        "summary": "Curtir tweet",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "tweetId", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "responses": {
          "200": {"description": "Tweet curtido com sucesso"},
          "400": {"description": "Não é possível curtir seu próprio tweet ou UUID inválido"},
          "401": {"description": "Token inválido"},
          "404": {"description": "Tweet não encontrado"},
          "500": {"description": "Erro inesperado"}
        }
      }
    },
    "/reply/{tweetId}": {
      "post": {
        "tags": ["Replies"],
        "summary": "Criar resposta",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "tweetId", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CreateTweet"}}}
        },
        "responses": {
          "200": {"description": "Reply cadastrado com sucesso"},
          "400": {"description": "Dados inválidos"},
          "401": {"description": "Token inválido"},
          "404": {"description": "Tweet original não encontrado"},
          "500": {"description": "Erro inesperado"}
        }
      }
    },
    "/reply/{id}": {
      "delete": {
        "tags": ["Replies"],
        "summary": "Apagar resposta",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "responses": {
          "200": {"description": "Reply deletado com sucesso"},
          "400": {"description": "UUID inválido"},
          "401": {"description": "Token inválido"},
          "404": {"description": "Reply não encontrado"},
          "500": {"description": "Erro inesperado"}
        }
      }
    },
    "/follower/follow/{id}": {
      "post": {
        "tags": ["Followers"],
        "summary": "Seguir usuário",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "responses": {
          "200": {"description": "Seguindo com sucesso"},
          "400": {"description": "Não é possível seguir a si mesmo ou UUID inválido"},
          "401": {"description": "Token inválido"},
          "404": {"description": "Usuário não encontrado"},
          "500": {"description": "Erro inesperado"}
        }
      }
    },
    "/follower/unfollow/{id}": {
      "delete": {
        "tags": ["Followers"],
        "summary": "Deixar de seguir usuário",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "responses": {
          "200": {"description": "Deixou de seguir com sucesso"},
          "400": {"description": "UUID inválido"},
          "401": {"description": "Token inválido"},
          "404": {"description": "Relação não encontrada"},
          "500": {"description": "Erro inesperado"}
        }
      }
    },
    "/follower": {
      "get": {
        "tags": ["Followers"],
        "summary": "Listar seguidores do usuário logado",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {"description": "Lista de seguidores gerada com sucesso"},
          "401": {"description": "Token inválido"},
          "500": {"description": "Erro inesperado"}
        }
      }
    },
    "/follower/following": {
      "get": {
        "tags": ["Followers"],
        "summary": "Listar usuários que o usuário logado segue",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {"description": "Lista de seguindo gerada com sucesso"},
          "401": {"description": "Token inválido"},
          "500": {"description": "Erro inesperado"}
        }
      }
    },
    "/feed": {
      "get": {
        "tags": ["Feed"],
        "summary": "Mostrar feed",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "limit", "in": "query", "required": false, "schema": {"type": "integer", "example": 10}},
          {"name": "page", "in": "query", "required": false, "schema": {"type": "integer", "example": 1}}
        ],
        "responses": {
          "200": {"description": "Feed listado com sucesso"},
          "401": {"description": "Token inválido"},
          "500": {"description": "Erro inesperado"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "CreateUser": {
        "type": "object",
        "required": ["name", "email", "username", "password"],
        "properties": {
          "name": {"type": "string", "example": "Pedro Henrique"},
          "email": {"type": "string", "format": "email", "example": "pedro@email.com"},
          "username": {"type": "string", "example": "pedro"},
          "password": {"type": "string", "example": "Pedro123"}
        }
      },
      "UpdateUser": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "example": "Pedro Henrique Atualizado"},
          "username": {"type": "string", "example": "pedro2"},
          "password": {"type": "string", "example": "Pedro1234"}
        }
      },
      "Login": {
        "type": "object",
        "required": ["password"],
        "properties": {
          "email": {"type": "string", "format": "email", "example": "pedro@email.com"},
          "username": {"type": "string", "example": "pedro"},
          "password": {"type": "string", "example": "Pedro123"}
        }
      },
      "CreateTweet": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": {"type": "string", "example": "Meu primeiro tweet pela API!"}
        }
      },
      "UpdateTweet": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": {"type": "string", "example": "Tweet atualizado"}
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid", "example": "9affb3d0-5969-4fcb-89c9-707fb5141653"},
          "name": {"type": "string", "example": "Pedro Henrique"},
          "email": {"type": "string", "format": "email", "example": "pedro@email.com"},
          "username": {"type": "string", "example": "pedro"},
          "createdAt": {"type": "string", "format": "date-time"},
          "deleted": {"type": "boolean", "example": false}
        }
      },
      "Tweet": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid", "example": "3e082ec4-a335-4401-a45a-1cdc8b89e3b0"},
          "content": {"type": "string", "example": "Meu primeiro tweet"},
          "type": {"type": "string", "enum": ["N", "R"], "example": "N"},
          "userId": {"type": "string", "format": "uuid"},
          "createdAt": {"type": "string", "format": "date-time"}
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "limit": {"type": "integer", "example": 10},
          "page": {"type": "integer", "example": 1},
          "totalPages": {"type": "integer", "example": 1},
          "count": {"type": "integer", "example": 1}
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "ok": {"type": "boolean", "example": false},
          "message": {"type": "string", "example": "Ocorreu um erro inesperado."}
        }
      }
    }
  }
}

